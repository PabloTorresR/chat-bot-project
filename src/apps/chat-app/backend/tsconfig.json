{
  "extends": "./tsconfig.extend.json",
  "compilerOptions": {
    "noImplicitAny": false,
    "target": "ES2021",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "noFallthroughCasesInSwitch": true,
    "jsx": "react-jsx",
    "baseUrl": "."
  },
  "include": [
    "*.config.js",
    "tsconfig.json",
    "tsconfig.node.json"
  ],
  "exclude": [
    "webpack.config.js",
    "node_modules"
  ],
  "ts-node": {
    "compilerOptions": {
      "esModuleInterop": true,
      "module": "commonjs",
      "moduleResolution": "Bundler",
      "noEmit": true,
      "allowSyntheticDefaultImports": true
    }
  }
}