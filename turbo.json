{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "outputs": [
        "dist/**"
      ]
    },
    "test": {},
    "type-check": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:sls": {
      "cache": false,
      "persistent": true,
      "dependsOn": [
        "^build"
      ]
    },
    "dev:local": {
      "dependsOn": [
        "^setup-dev:local",
        "setup-dev:local"
      ],
      "cache": false,
      "persistent": true
    },
    "setup-dev:local": {
      "cache": false
    }
  }
}